{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "recipes.schema.json",
  "title": "Recipes",
  "description": "Originals, confirmed favorites, and the wishlist.",
  "type": "object",
  "properties": {
    "last_updated": { "type": "string", "format": "date" },
    "originals": {
      "type": "array",
      "items": { "$ref": "#/definitions/original" },
      "description": "Cocktails created specifically for or by the bar owner."
    },
    "profile_coverage_matrix": {
      "type": "array",
      "description": "Quick-reference view of originals across base/method/profile dimensions.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^cocktail[0-9]+$" },
          "name": { "type": "string" },
          "creator": { "type": "string" },
          "base": { "type": "string" },
          "method": { "type": "string", "enum": ["shaken", "stirred", "built", "blended", "thrown", "other"] },
          "profile_occasion": { "type": "string" }
        }
      }
    },
    "confirmed_favorites": {
      "type": "array",
      "items": { "$ref": "#/definitions/confirmedFavorite" },
      "description": "Classics and agent-suggestions the bar owner has actually built and approved."
    },
    "wishlist": {
      "type": "array",
      "items": { "$ref": "#/definitions/savedRecipe" },
      "description": "Recipes bookmarked to try. Full recipe stored inline at save time."
    },
    "made_log": {
      "type": "array",
      "items": { "$ref": "#/definitions/madeEntry" },
      "description": "Recipes the bar owner has made. Most-recent first. Full recipe stored inline at save time."
    }
  },
  "definitions": {
    "ingredient": {
      "type": "object",
      "required": ["name", "amount"],
      "properties": {
        "name": { "type": "string" },
        "amount": { "type": "string", "description": "e.g., '2 oz', '¾ oz', 'dash', 'barspoon'" },
        "notes": { "type": "string", "description": "e.g., 'fresh squeezed', 'chilled'" }
      }
    },
    "original": {
      "type": "object",
      "required": ["id", "name", "creator", "ingredients", "method"],
      "properties": {
        "id": { "type": "string", "pattern": "^cocktail[0-9]+$" },
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "creator": { "type": "string", "description": "Full attribution string." },
        "date_created": { "type": "string", "format": "date" },
        "ingredients": {
          "type": "array",
          "items": { "$ref": "#/definitions/ingredient" }
        },
        "method": { "type": "string" },
        "method_type": {
          "type": "string",
          "enum": ["shaken", "stirred", "built", "blended", "thrown", "other"]
        },
        "garnish": { "type": "string" },
        "glassware": { "type": "string" },
        "profile": { "type": "string", "description": "Brief flavor/occasion description." },
        "why_it_works": { "type": "string" },
        "variations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "filename": { "type": "string", "description": "e.g., 'cocktail7_smokey_the_pear_001.png'" },
              "style": { "type": "string", "enum": ["photorealistic", "illustrated", "other"] },
              "alt_text": { "type": "string" }
            }
          }
        },
        "image_gen_prompts": {
          "type": "object",
          "properties": {
            "photorealistic": { "type": "string" },
            "illustrated": { "type": "string" }
          }
        },
        "ratings": {
          "type": "object",
          "properties": {
            "bar_owner": { "type": "integer", "minimum": 1, "maximum": 10 },
            "guests": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "confirmed_built": { "type": "boolean", "description": "Whether the bar owner has actually made this." },
        "date_confirmed": { "type": ["string", "null"], "format": "date" }
      }
    },
    "confirmedFavorite": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "creator": { "type": "string" },
        "date_confirmed": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "adaptation": { "type": "string", "description": "Any modifications from the canonical recipe." },
        "ingredients": {
          "type": "array",
          "items": { "$ref": "#/definitions/ingredient" }
        },
        "method": { "type": "string" },
        "garnish": { "type": "string" }
      }
    },
    "savedRecipe": {
      "type": "object",
      "required": ["name"],
      "description": "Full recipe stored inline at save time (Favorites, Wishlist).",
      "properties": {
        "_source": { "type": "string", "description": "Provenance: classics-db | originals | ai-generated" },
        "name": { "type": "string" },
        "base": { "type": "string" },
        "method": { "type": "string" },
        "glassware": { "type": "string" },
        "garnish": { "type": "string" },
        "occasion": { "type": "string" },
        "ingredients": {
          "type": "array",
          "items": { "$ref": "#/definitions/ingredient" }
        },
        "notes": { "type": "string" }
      }
    },
    "madeEntry": {
      "type": "object",
      "required": ["name"],
      "description": "Full recipe + tracking metadata stored inline at save time.",
      "properties": {
        "_source": { "type": "string", "description": "Provenance: classics-db | originals | ai-generated" },
        "name": { "type": "string" },
        "base": { "type": "string" },
        "method": { "type": "string" },
        "glassware": { "type": "string" },
        "garnish": { "type": "string" },
        "occasion": { "type": "string" },
        "ingredients": {
          "type": "array",
          "items": { "$ref": "#/definitions/ingredient" }
        },
        "times_made": { "type": "integer", "minimum": 1 },
        "first_made": { "type": "string", "format": "date" },
        "last_made": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    }
  }
}
